# ─── Base de données ───────────────────────────────────────────────────────────
# Railway fournit cette variable automatiquement quand vous ajoutez un service PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/kaizen_reporting

# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Sécurité JWT ──────────────────────────────────────────────────────────────
# OBLIGATOIRE : Remplacer par une clé aléatoire forte (ex: openssl rand -base64 64)
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_FORTE

JWT_EXPIRES_IN=8h

# ─── CORS ──────────────────────────────────────────────────────────────────────
# URL Vercel du frontend (ex: https://kaizen-reporting.vercel.app)
# Plusieurs origines séparées par des virgules : url1,url2
CORS_ORIGIN=https://VOTRE_APP.vercel.app

# ─── Taux de conversion ────────────────────────────────────────────────────────
TAUX_CFA_EUR=655.957
